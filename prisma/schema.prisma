generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──

enum InvoiceType {
  NFE
  CTE
  NFSE
}

enum InvoiceDirection {
  received
  issued
}

enum InvoiceStatus {
  received
  confirmed
  rejected
}

enum SyncMethod {
  sefaz
  nsdocs
  receita_nfse
}

enum SyncStatus {
  running
  completed
  partial
  error
}

enum UserRole {
  admin
  editor
  viewer
}

enum UserStatus {
  pending
  active
  inactive
  rejected
}

enum AccessLogAction {
  login
  login_failed
  logout
  navigation
  api_key_used
  user_created
  user_updated
  user_deleted
  role_changed
  status_changed
  pages_changed
  permission_denied
  account_locked
}

// ── Models ──

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String
  name           String
  phone          String?
  role           UserRole   @default(viewer)
  status         UserStatus @default(pending)
  allowedPages   String[]   @default([])
  // PIN brute-force protection: incremented on failed login, reset on success.
  // lockedUntil is a soft lock — authorize() rejects the login while now < lockedUntil.
  failedAttempts Int        @default(0)
  lockedUntil    DateTime?
  // Session revocation counter — every issued JWT embeds this value in its
  // `tokenVersion` claim. Increment to invalidate ALL outstanding sessions
  // for this user (logout-everywhere, role demotion, status change, etc.).
  tokenVersion   Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  companies      Company[]
  accessLogs     AccessLog[]
  apiKeys        ApiKey[]   @relation("ApiKeyCreator")
}

// Named API keys used by external integrations (n8n, scripts). Each row
// stores a SHA-256 hash of the raw key — the clear value is shown once
// at creation time and never retrievable afterward. Revocation is a soft
// delete via revokedAt so historical audit trails keep pointing to a
// valid row.
model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  scopes      String[]  @default([])
  createdById String
  createdBy   User      @relation("ApiKeyCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  lastUsedAt  DateTime?

  @@index([revokedAt])
}

model AccessLog {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    AccessLogAction
  path      String?
  createdAt DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

model Company {
  id           String    @id @default(cuid())
  cnpj         String    @unique
  razaoSocial  String
  nomeFantasia String?
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices          Invoice[]
  duplicataOverrides FinanceiroDuplicataOverride[]
  manualInstallments FinanceiroDuplicataManualInstallment[]
  contactNicknames   ContactNickname[]
  contactOverrides   ContactOverride[]
  nsdocsConfig      NsdocsConfig?
  receitaNfseConfig ReceitaNfseConfig?
  certificateConfig CertificateConfig?
  oneDriveConnections OneDriveConnection[]
  syncLogs          SyncLog[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
}

model NsdocsConfig {
  id           String    @id @default(cuid())
  apiToken     String
  companyId    String    @unique
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  autoSync     Boolean   @default(true)
  syncInterval Int       @default(60)
  lastNsu      String?
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ReceitaNfseConfig {
  id           String   @id @default(cuid())
  companyId    String   @unique
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  apiToken     String?
  autoSync     Boolean  @default(true)
  syncInterval Int      @default(60)
  environment  String   @default("production")
  baseUrl      String?
  cnpjConsulta String?
  lastNsu      String   @default("000000000000000")
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CertificateConfig {
  id              String    @id @default(cuid())
  companyId       String    @unique
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pfxData         Bytes
  pfxPassword     String
  serialNumber    String?
  issuer          String?
  subject         String?
  validFrom       DateTime?
  validTo         DateTime?
  cnpjCertificate String?
  environment     String    @default("production")
  lastNsu         String    @default("000000000000000")
  lastSyncAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model SyncLog {
  id           String     @id @default(cuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  syncMethod   SyncMethod @default(sefaz)
  status       SyncStatus @default(running)
  newDocs      Int        @default(0)
  updatedDocs  Int        @default(0)
  skippedDocs  Int        @default(0)
  errorMessage String?
  startedAt    DateTime   @default(now())
  completedAt  DateTime?

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, syncMethod, status])
}

model OneDriveConnection {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountEmail    String
  accountName     String?
  microsoftUserId String?
  driveId         String
  driveType       String?
  driveWebUrl     String?
  accessToken     String
  refreshToken    String?
  tokenExpiresAt  DateTime
  scope           String?
  lastValidatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([companyId, accountEmail])
  @@index([companyId])
}

model Invoice {
  id             String           @id @default(cuid())
  accessKey      String           @unique
  type           InvoiceType
  direction      InvoiceDirection @default(received)
  number         String
  series         String?
  issueDate      DateTime
  senderCnpj     String
  senderName     String
  recipientCnpj  String?
  recipientName  String?
  totalValue     Decimal
  status         InvoiceStatus    @default(received)
  cfop           String?
  xmlContent     String
  companyId      String
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  duplicataOverrides FinanceiroDuplicataOverride[]
  manualInstallments FinanceiroDuplicataManualInstallment[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([companyId])
  @@index([senderCnpj])
  @@index([issueDate])
  @@index([companyId, type, direction])
  @@index([companyId, type, direction, issueDate])
  @@index([companyId, type, direction, senderCnpj])
  @@index([companyId, status])
  @@index([companyId, cfop])
  @@index([senderName])
  @@index([recipientCnpj])
  @@index([companyId, recipientCnpj])
}

model FinanceiroDuplicataOverride {
  id                    String   @id @default(cuid())
  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceId             String
  invoice               Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  dupNumeroOriginal     String
  dupVencimentoOriginal String
  emitenteNome          String?
  emitenteCnpj          String?
  faturaNumero          String?
  dupNumero             String?
  dupVencimento         String?
  dupValor              Decimal?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([companyId, invoiceId, dupNumeroOriginal, dupVencimentoOriginal], map: "company_invoice_dup_original")
  @@index([companyId])
  @@index([invoiceId])
  @@index([companyId, invoiceId])
}

model ContactNickname {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cnpj      String
  shortName String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, cnpj])
  @@index([companyId])
}

model ContactOverride {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cnpj        String
  phone       String?
  email       String?
  street      String?
  number      String?
  complement  String?
  district    String?
  city        String?
  state       String?
  zipCode     String?
  country     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, cnpj])
  @@index([companyId])
}

model FinanceiroDuplicataManualInstallment {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  dupNumero     String
  dupVencimento String
  dupValor      Decimal
  dupDesconto   Decimal  @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, invoiceId, dupNumero], map: "company_invoice_manual_dup_num")
  @@index([companyId])
  @@index([invoiceId])
  @@index([companyId, invoiceId])
}


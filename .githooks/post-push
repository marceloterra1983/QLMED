#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-}"
remote_url="${2:-}"
deploy_remote="${AUTO_DEPLOY_REMOTE:-origin}"
deploy_branch="${AUTO_DEPLOY_BRANCH:-main}"
repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ "${SKIP_SERVER_DEPLOY:-0}" == "1" ]]; then
  exit 0
fi

if [[ "$remote_name" != "$deploy_remote" ]]; then
  exit 0
fi

should_deploy=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -z "${local_ref:-}" ]] && continue

  if [[ "$remote_ref" == "refs/heads/$deploy_branch" && "$local_sha" != "0000000000000000000000000000000000000000" ]]; then
    should_deploy=1
    break
  fi
done

if [[ "$should_deploy" -ne 1 ]]; then
  exit 0
fi

if [[ "${DEPLOY_HOOK_DRY_RUN:-0}" == "1" ]]; then
  echo "post-push: dry-run matched ${deploy_branch} on ${remote_name}; deploy would run now."
  exit 0
fi

echo "post-push: triggering deploy to server for ${deploy_branch} via ${remote_name} (${remote_url})"
cd "$repo_root"
bash ./scripts/deploy-server.sh

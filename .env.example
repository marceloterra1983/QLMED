# ============================================================
# QLMED — Environment Variables
# Copy to .env and fill in values before running.
# Lines marked [REQUIRED] must be set; others have defaults.
# ============================================================

# ── Database (PostgreSQL) ──────────────────────────────────
# [REQUIRED] Connection string for the app
DATABASE_URL="postgresql://qlmed:password@qlmed-db:5432/qlmed?schema=public"
# [REQUIRED] Password used by both docker-compose and DATABASE_URL
POSTGRES_PASSWORD="CHANGE_ME_GENERATE_SECURE_PASSWORD"

# ── NextAuth ───────────────────────────────────────────────
# [REQUIRED] Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://app.qlmed.com.br"
# Optional (dev only): comma-separated origins allowed to fetch /_next/* from another host/IP.
# Example: NEXT_ALLOWED_DEV_ORIGINS="100.123.233.116,qlmed.local"
NEXT_ALLOWED_DEV_ORIGINS=""

# ── Encryption key for sensitive data (certificates, tokens) ──
# [REQUIRED] Generate with: openssl rand -base64 32
ENCRYPTION_KEY="generate-with-openssl-rand-base64-32"

# ── Microsoft Graph / OneDrive (OAuth) ─────────────────────
# Optional — only needed for OneDrive XML sync
TENANT_ID="00000000-0000-0000-0000-000000000000"
CLIENT_ID="00000000-0000-0000-0000-000000000000"
CLIENT_SECRET="paste-your-client-secret-value"
REDIRECT_URI="http://localhost:43000/auth/callback"

# ── Single company mode (QL MED) ──────────────────────────
SINGLE_COMPANY_CNPJ="07832309000197"
SINGLE_COMPANY_RAZAO_SOCIAL="QL MED MATERIAIS HOSPITALARES LTDA"
SINGLE_COMPANY_NOME_FANTASIA="QLMED"

# ── Local XML watcher ─────────────────────────────────────
# Optional — auto-imports XMLs from a watched directory
LOCAL_XML_WATCH_ENABLED="true"
LOCAL_XML_WATCH_DIR="/path/to/xml/folder"
LOCAL_XML_WATCH_FALLBACK_DIR="/path/to/fallback/folder"
LOCAL_XML_RESCAN_INTERVAL_MS="10000"
LOCAL_XML_BOOTSTRAP_RETRY_MS="10000"
LOCAL_XML_FORCED_MIN_INTERVAL_MS="5000"
LOCAL_XML_WATCH_STABILITY_MS="1500"
LOCAL_XML_FULL_RECONCILE_ENABLED="true"
LOCAL_XML_FULL_RECONCILE_MONTH_FOLDERS="2"
LOCAL_XML_COPY_ENABLED="false"
LOCAL_XML_COPY_SOURCE_DIR="/path/to/source"
LOCAL_XML_COPY_TARGET_DIR="/path/to/target"
LOCAL_XML_COPY_INTERVAL_MS="60000"
LOCAL_XML_COPY_MONTH_FOLDERS="2"
LOCAL_XML_COPY_ONEDRIVE_ENABLED="true"
LOCAL_XML_ONEDRIVE_XML_PATH="/BACKUP_QL MED/NFE/XML"
LOCAL_XML_ONEDRIVE_MONTH_FOLDERS="2"

# ── Receita NFS-e (ADN) ──────────────────────────────────
# Optional — set to "false" apenas se houver problema de cadeia SSL no ambiente
RECEITA_NFSE_VERIFY_SSL="true"

# ── n8n Integration ───────────────────────────────────────
# [REQUIRED] Shared API key for n8n ↔ QLMED. Generate with: openssl rand -hex 32
QLMED_API_KEY="generate-with-openssl-rand-hex-32"
N8N_BASIC_AUTH_ACTIVE="true"
N8N_BASIC_AUTH_USER="admin"
N8N_BASIC_AUTH_PASSWORD="CHANGE_ME_GENERATE_SECURE_PASSWORD"
N8N_HOST="localhost"
N8N_PROTOCOL="http"
N8N_WEBHOOK_URL="http://localhost:5678/"

# ── Coolify (self-hosted PaaS) ────────────────────────────
# Optional — only needed for automated deploys
COOLIFY_URL="http://localhost:8000"
COOLIFY_API_TOKEN="your-coolify-api-token"
COOLIFY_APP_UUID="kcc4kcckg4gg48c8k8g80occ"
COOLIFY_SERVER_UUID="iskgsg00gg0sc48wgw8scccw"
COOLIFY_PROJECT_UUID="qck8cwgcg4o0gsck0kk0kso4"

# ── SMTP (email sending) ─────────────────────────────────
# [REQUIRED for email] Without SMTP_PASS, PDF email sending will fail
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_USER="adm@qlmed.com.br"
SMTP_PASS=""
